# ============================================================
# CVio — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
# Your OpenAI API key (required for all AI features)
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# Firebase Client SDK (exposed to the browser — NEXT_PUBLIC_*)
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ------------------------------------------------------------
# Firebase Admin SDK (server-side only — never expose to browser)
# ------------------------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key from your service account JSON.
# Replace literal newlines with \n so it fits on one line.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# ------------------------------------------------------------
# Optional — Firebase Emulator (used in tests / local dev)
# ------------------------------------------------------------
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ------------------------------------------------------------
# Optional — Puppeteer
# ------------------------------------------------------------
# Set to "true" to skip Chromium download / PDF export tests
# PUPPETEER_SKIP_DOWNLOAD=true
# SKIP_PUPPETEER=true
